# BrainTrust IDE v3 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_strong_password
DB_HOST=mysql
DB_USER=braintrust_user
DB_PASS=change_me_strong_password
DB_NAME=braintrust_ide

# ── Dev DB (for AI-created projects that use a MySQL database) ────────────────
# Uses same MySQL instance and same braintrust_user — just a separate database.
DEV_DB_NAME=dev_projects
# DEV_DB_HOST, DEV_DB_USER, DEV_DB_PASS default to DB_* values above

# ── AI API Keys ───────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=                   # Optional — only needed for OpenAI fallback
OPENAI_MODEL=gpt-4o

# ── GitHub Integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...              # Personal access token (repo scope)
GITHUB_USERNAME=your_github_username

# ── Port Mapping (host:container) ─────────────────────────────────────────────
APP_PORT=80          # Apache HTTP
WS_PORT=8081         # WebSocket chat
TERM_PORT=8083       # WebSocket terminal

# ── App ───────────────────────────────────────────────────────────────────────
# Base path for PHP/HTML web previews. Leave as-is unless you change Apache docroot.
APP_BASE_PATH=/collabchat/projects
